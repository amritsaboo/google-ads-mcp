# Google Ads API Credentials
GOOGLE_ADS_DEVELOPER_TOKEN="your_developer_token_here"
GOOGLE_PROJECT_ID="your_google_cloud_project_id_here"

# OAuth Credentials (Required for HTTP/SSE transport)
GOOGLE_ADS_MCP_OAUTH_CLIENT_ID="your_oauth_client_id_here"
GOOGLE_ADS_MCP_OAUTH_CLIENT_SECRET="your_oauth_client_secret_here"

# Optional: Manager Customer ID (if accessing via a manager account)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID="your_manager_id_here"

# Optional: Base URL (for SSE transport)
# GOOGLE_ADS_MCP_BASE_URL="https://your-app-name.up.railway.app"

# Optional: Port (Railway will set this automatically)
# PORT=8000
